# ==============================================================================
# OpenBao + Route53 Example — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   go run main.go
# ==============================================================================

# ── OpenBao (Secrets Management) ─────────────────────────────────────────────
# OpenBao API address
VAULT_ADDR=http://localhost:8200
# OpenBao root/service token (with read access to secret/csp/aws)
VAULT_TOKEN=

# ── Route53 Query ─────────────────────────────────────────────────────────────
# Domain to look up in Route53 (e.g. example.com)
ROUTE53_DOMAIN=example.com
